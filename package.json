{
  "name": "jssm4",
  "version": "2.0.0",
  "description": "国密SM4加解密工具，支持浏览器与Node环境",
  "main": "lib/jssm4.cjs.js",
  "module": "lib/jssm4.esm.js",
  "browser": "lib/jssm4.js",
  "types": "index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./lib/jssm4.esm.js",
      "require": "./lib/jssm4.cjs.js",
      "default": "./lib/jssm4.js"
    }
  },
  "files": [
    "lib",
    "index.d.ts",
    "README.md"
  ],
  "private": false,
  "scripts": {
    "test": "node ./test/index.test.js",
    "dev": "rollup -c -w",
    "build": "rollup -c",
    "demo": "serve . -p 3000",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhangyu921/jssm4.git"
  },
  "keywords": [
    "sm4"
  ],
  "author": "zhangyu921",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0 <21.0.0",
    "npm": ">=10.0.0"
  },
  "bugs": {
    "url": "https://github.com/zhangyu921/jssm4/issues"
  },
  "homepage": "https://github.com/zhangyu921/jssm4#readme",
  "dependencies": {
    "base64-js": "^1.3.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "rollup": "^4.55.1",
    "serve": "^14.2.5"
  }
}
